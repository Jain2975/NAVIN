# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Database ─────────────────────────────────────────────────────────
# Local development (SQLite — no setup needed)
DATABASE_URL=sqlite:///./navin.db

# Production (Supabase — get from: supabase.com → Settings → Database → URI)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Security ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX

# ── App ──────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated, no spaces
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example:
# CORS_ORIGINS=https://navin.vercel.app,https://navin-staging.vercel.app
